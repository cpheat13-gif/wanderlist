EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: powers auto-fetched destination cover photos on new trips.
# Without it, trip creation still works — just no cover photo.
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Required for the Discover tab (AI trip planner). Point this at your Vercel
# deployment URL — the app calls <this-url>/api/claude, which proxies to Anthropic.
# Do NOT put your Anthropic API key here; that key only goes in Vercel's env vars
# (see README) and must never be prefixed with EXPO_PUBLIC_.
EXPO_PUBLIC_API_BASE_URL=https://your-app.vercel.app
